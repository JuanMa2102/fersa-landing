---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Stats2 from '~/components/widgets/Stats2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import AboutCard from '~/components/widgets/AboutCard.astro';
import Catalog from '~/components/widgets/Catalog.astro';
import Branches from '~/components/widgets/Branches.astro';

const metadata = {
  title: 'Fersa — Ferremotobombas',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Catálogo',
        href: 'catalogo_fersa.pdf',
        target: '_blank',
        icon: 'tabler:download',
      },
      { text: 'Sucursales', href: '#sucursales' },
    ]}
    image={{ src: '~/assets/images/fersa-chair.png', alt: 'Aberlin imagen' }}
  >
    <Fragment slot="title">
      Con más de <span class="text-primary dark:text-secondary">45 años de experiencia</span> en el mercado
    </Fragment>

    <Fragment slot="subtitle">
      En <span class="font-semibold">FERSA</span> nos especializamos en la venta, refacciones y mantenimiento de equipos forestales, agrícolas y de jardinería. Nos enorgullece ser distribuidores autorizados de marcas líderes a nivel mundial como <span class="font-bold">Husqvarna, Oregon, Cifarelli, Koshin, Afosa</span> en productos de fuerza. Nuestro compromiso es brindar soluciones de calidad, para profesionales y entusiastas del campo, la jardinería y el manejo forestal, asegurando un servicio técnico especializado y productos confiables que superan las expectativas de nuestros clientes.
    </Fragment>
  </Hero>

  <Features
    backgroundColor="bg-husqvarna text-white"
    classes={{ headline: { title: 'text-white', subtitle: 'text-white' } }}
    id="services"
    tagline=""
    title="Nuestros servicios"
    subtitle=""
    items={[
      {
        title: 'Venta de Equipos y Refacciones',
        description:
          'Ofrecemos una amplia gama de equipos forestales, agrícolas y de jardinería de las marcas más confiables del mercado. Además, contamos con refacciones originales para garantizar el óptimo funcionamiento de tus equipos.',
        icon: 'tabler:currency-dollar',
        image_link: { image: '~/assets/images/aberlin_mecanico.png' }
      },
      {
        title: 'Mantenimiento Preventivo y Correctivo',
        description:
          'Visita nuestro Taller Mecánico Especializado, donde brindamos servicio de mantenimiento preventivo y correctivo para mantener tus equipos en perfecto estado. Nuestro equipo de expertos se asegura de que tu maquinaria esté siempre lista para el trabajo, aumentando su vida útil y rendimiento.',
        icon: 'tabler:tool',
        image_link: { image: '~/assets/images/aberlin_like.png' }
      },
    ]}
  />

  <Catalog
    stats={[
      { image: 'accesorios.png', title: 'ACCESORIOS'},
      { image: 'aceites_y_lubricantes.png', title: 'ACEITES Y LUBRICANTES'},
      { image: 'consumibles.png', title: 'CONSUMIBLES'},
      { image: 'equipos_de_proteccion_personal.png', title: 'EQUIPOS DE PROTECCIÓN PERSONAL'},
      { image: 'equipos.png', title: 'EQUIPOS'},
      { image: 'herramientas.png', title: 'HERRAMIENTAS'},
      { image: 'refacciones.png', title: 'REFACCIONES'},
      { image: 'riego_y_poda.png' , title: 'RIEGO Y PODA'},
    ]}
  />

  <!-- Branches Widget ****************** -->
  <Branches
    id="sucursales"
    title="Ubicación de nuestras sucursales"
    subtitle="Visítanos en cualquiera de nuestras sucursales para recibir atención personalizada."
    items={[
      {
        title: 'Matriz San Cristóbal de las Casas',
        description: 'Blvd. Juan Sabines Gtz. No. 5-D Barrio San Diego /C.P. 29270 San Cristóbal de las Casas, Chiapas.',
        image: '/sancristobal.jpeg',
        horario: 'Lun - Vie: 7:00am a 6:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9671928700',
          telefono: '9676782735',
          ubicacion: 'https://maps.app.goo.gl/nCaGBDvpuJfvKZXf7',
        },
      },
      {
        title: 'Huixtla',
        description: 'Calle Negrete Pte. Local #2, Col. Centro C.P. 30640 / Huixtla, Chiapas',
        image: '/huixtla.jpeg',
        horario: 'Lun - Vie: 8:00am a 5:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9641393622',
          telefono: '9646420060',
          ubicacion: 'https://maps.app.goo.gl/UT5ZjpJ3RtD2PYJj6',
        },
      },
      {
        title: 'Pijijiapan',
        description: '3a Av. Norte Poniente No. 26-A / Centro, C.P. 30540 / Pijijiapan, Chiapas.',
        image: '/pijijiapan.jpeg',
        horario: 'Lun - Vie: 8:00am a 5:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9181047654',
          telefono: '9186451201',
          ubicacion: 'https://maps.app.goo.gl/Gu7guSuzh6QUPxTu5',
        },
      },
      {
        title: 'Cintalapa',
        description: 'Calle Central Sur No. 154-B / Barrio Guadalupe. Cintalapa de Figueroa, Chiapas.',
        image: '/cintalapa.jpeg',
        horario: 'Lun - Vie: 8:00am a 5:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9687442740',
          telefono: '9686843754',
          ubicacion: 'https://maps.app.goo.gl/kgeYjEPpKxn1cb6p9',
        },
      },
      {
        title: 'Tapachula',
        description: '3a- Ote. No. 34-C Esquina 5a Norte / Centro C.P. 30700 / Tapachula, Chiapas.',
        image: '/tapachula.jpeg',
        horario: 'Lun - Vie: 8:00am a 5:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9621370262',
          telefono: '9626255431',
          ubicacion: 'https://maps.app.goo.gl/nP9kg4i9tJsJ2ESN6',
        },
      },
      {
        title: 'Coita',
        description: 'Av. 1a Sur Poniente #236, entre 1a y 2a Poniente / C.P 29140, Ocozocoautla de Figueroa, Chiapas',
        image: '/ocozocoautla.jpeg',
        horario: 'Lun - Vie: 8:00am a 5:00pm | Sáb: 8:00am a 2:00pm',
        telefonos: {
          whatsapp: '9681176905',
          telefono: '9686881174',
          ubicacion: 'https://maps.app.goo.gl/jhpXq8DURA5TFyDFA',
        },
      },
    ]}
  />

  <AboutCard tagline="Quienes somos" id="about" backgroundColor='bg-husqvarna dark:bg-secondary text-white'>
    <Fragment slot="title">
      Con más de 40 años de experiencia<br />
    </Fragment>
      <span slot="subtitle" class="text-white dark:text-white">
        <span class="text-white dark:text-white" >En <span class="font-semibold">Fersa</span> nos especializamos en la venta, refacciones y mantenimiento de equipos
        forest</span>ales, agrícolas y de jardinería. Nos enorgullece ser distribuidores autorizados de marcas líderes a nivel mundial
        como <span class="text-primary dark:text-white"> Husqvarna, Oregon, Cifarelli y Koshin </span> en productos
        de fuerza. Nuestro compromiso es brindar soluciones de calidad para profesionales y entusiastas del campo, la jardinería
        y el manejo forestal, asegurando un servicio técnico especializado y productos confiables que superan las expectativas
        de nuestros clientes.
      </span>
    </Fragment>
    <Fragment slot="steps">
      <Steps2
        title=""
        subtitle=""
        items={[
          {
            title: 'Visión',
            description:
              'Ser la mejor empresa del sureste mexicano con la mejor atención y servicio en el sector forestal, agricola y jardineria, ofreciendo solo productos de las mas alta calidad con los mejores precios del mercado a todos nuestros clientes.',
          },
          {
            title: 'Misión',
            description:
              'Proporcionar a nuestros clientes las herramientas necesarias con los mas altos estandares de calidad para lograr un mejor desempeño y productividad en su trabajo diario, cubriendo sus expectativas en el giro forestal, agricola y jardinería.',
          },
        ]}
      />
    </Fragment>
  </AboutCard>

  <Stats2
    stats={[
      { image: '~/assets/images/husq.png' }
    ]}
  />
  <Stats
    stats={[
      { image: '~/assets/images/koshin-logo.png' },
      { image: '~/assets/images/afosa-logo.png' },
      { image: '~/assets/images/oregon-logo.png' },
      { image: '~/assets/images/toyama.webp' },
      { image: '~/assets/images/cifarelli-logo.webp', object_fit: 'cover' },
      { image: '~/assets/images/bahco-logo.svg' },
      { image: '~/assets/images/gardena-logo.svg' },
    ]}
  />

  <!--CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Catálogo',
        href: 'catalogo_fersa.pdf',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      El equipo que buscas está en <br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Fersa</span>
    </Fragment>

    <Fragment slot="subtitle">
      Descarga nuestro catálogo y descubre las mejores herramientas para tu trabajo.
    </Fragment>
  </CallToAction>
</Layout >
